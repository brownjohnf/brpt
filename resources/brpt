#!/bin/bash

SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
APP_PATH="$(dirname "$(dirname "$SCRIPT_DIR")")"

# Resolve file paths to absolute before passing to open
FILES=()
for arg in "$@"; do
  if [ -f "$arg" ]; then
    FILES+=("$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")")
  fi
done

if [ ${#FILES[@]} -eq 0 ]; then
  open -a "$APP_PATH"
else
  open -a "$APP_PATH" "${FILES[@]}"
fi
