#!/usr/bin/env python3

import json
import os
import subprocess
import sys
import tempfile

PLATFORM = sys.platform


def find_app_path():
    source = os.path.realpath(__file__)
    script_dir = os.path.dirname(source)
    if PLATFORM == "darwin":
        # macOS: script is at App.app/Contents/Resources/brpt → walk up to App.app/
        return os.path.dirname(os.path.dirname(script_dir))
    # Linux: AppImage is co-located with the script in the same directory
    return script_dir


def load_dev_roots(config_path):
    try:
        with open(config_path) as f:
            cfg = json.load(f)
        return cfg.get("brpt_development_roots", [])
    except Exception:
        return []


def dev_electron_bin(root):
    """Path to the electron binary inside a dev checkout's node_modules."""
    if PLATFORM == "darwin":
        return os.path.join(root, "node_modules/electron/dist/Electron.app/Contents/MacOS/Electron")
    return os.path.join(root, "node_modules/electron/dist/electron")


def dev_electron_app(root):
    """Path to the electron app directory used as target_app for a dev instance."""
    if PLATFORM == "darwin":
        return os.path.join(root, "node_modules/electron/dist/Electron.app")
    return os.path.join(root, "node_modules/electron/dist")


def find_app_binary(app_path):
    """Find the executable binary for the packaged app."""
    if PLATFORM == "darwin":
        macos_dir = os.path.join(app_path, "Contents", "MacOS")
        entries = os.listdir(macos_dir)
        if len(entries) == 1:
            return os.path.join(macos_dir, entries[0])
        app_name = os.path.basename(app_path).replace(".app", "")
        for entry in entries:
            if entry == app_name:
                return os.path.join(macos_dir, entry)
        return os.path.join(macos_dir, entries[0])

    # Linux: AppImage is co-located with the brpt script.
    script_name = os.path.basename(os.path.realpath(__file__))
    for name in os.listdir(app_path):
        if name.endswith(".AppImage"):
            path = os.path.join(app_path, name)
            if os.path.isfile(path) and os.access(path, os.X_OK):
                return path
    for name in os.listdir(app_path):
        path = os.path.join(app_path, name)
        if (os.path.isfile(path) and os.access(path, os.X_OK)
                and name != script_name and not name.endswith(".so")):
            return path
    print("brpt: could not find AppImage in " + app_path, file=sys.stderr)
    print("brpt: reinstall with 'npm run install:linux'", file=sys.stderr)
    sys.exit(1)


def find_running_dev_instance(dev_roots):
    for root in dev_roots:
        electron_bin = dev_electron_bin(root)
        try:
            result = subprocess.run(
                ["pgrep", "-qf", electron_bin],
                capture_output=True,
            )
            if result.returncode == 0:
                return dev_electron_app(root)
        except Exception:
            continue
    return None


def stdin_bridge_index(args):
    """Find the index of a `-` arg that means 'read from stdin'.

    Returns the index of `-` if found in a position where it serves as
    the message body for `notify` or `annotate add`, otherwise -1.
    """
    try:
        idx = args.index("-")
    except ValueError:
        return -1
    # `-` must come after a command that accepts a message body
    preceding = args[:idx]
    # `brpt notify <target> -`
    if "notify" in preceding:
        return idx
    # `brpt annotate add <target> <line> -`
    if "annotate" in preceding and "add" in preceding:
        return idx
    return -1


def main():
    config_path = os.environ.get("BRPT_CONFIG") or os.path.join(
        os.path.expanduser("~"), ".brpt", "brpt-config.json"
    )
    app_path = find_app_path()
    dev_roots = load_dev_roots(config_path)
    dev_app = find_running_dev_instance(dev_roots)
    target_app = dev_app or app_path

    # In dev mode, pass the project root as the entry point so Electron
    # reads package.json → main. For packaged apps, the entry is baked in.
    dev_entry = []
    if dev_app:
        for root in dev_roots:
            if os.path.normpath(dev_electron_app(root)) == os.path.normpath(target_app):
                dev_entry = [root]
                break

    app_bin = find_app_binary(target_app)
    user_args = sys.argv[1:]

    # Stdin bridge: when the user passes `-` as the message body for
    # `notify` or `annotate add`, read stdin, write to a temp file, and
    # replace `-` with --message-file=<path>. Stdin can't cross the
    # Electron second-instance boundary, so the launcher materializes
    # it as a file for Electron to read.
    dash_idx = stdin_bridge_index(user_args)
    if dash_idx != -1:
        content = sys.stdin.read()
        tmp = tempfile.NamedTemporaryFile(
            prefix="brpt-msg-", suffix=".md", delete=False, mode="w"
        )
        tmp.write(content)
        tmp.close()
        user_args = user_args[:dash_idx] + [f"--message-file={tmp.name}"] + user_args[dash_idx + 1:]

    cmd = [app_bin] + dev_entry + ["--"] + user_args
    result = subprocess.run(cmd)
    sys.exit(result.returncode)


if __name__ == "__main__":
    main()
