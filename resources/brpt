#!/usr/bin/env python3

import argparse
import json
import os
import subprocess
import sys

def resolve_path(path):
    return os.path.realpath(path)

def find_app_path():
    source = os.path.realpath(__file__)
    script_dir = os.path.dirname(source)
    return os.path.dirname(os.path.dirname(script_dir))

def load_dev_roots(config_path):
    try:
        with open(config_path) as f:
            cfg = json.load(f)
        return cfg.get("brpt_development_roots", [])
    except Exception:
        return []

def find_app_binary(app_path):
    """Find the executable binary inside a .app bundle."""
    macos_dir = os.path.join(app_path, "Contents", "MacOS")
    entries = os.listdir(macos_dir)
    if len(entries) == 1:
        return os.path.join(macos_dir, entries[0])
    # Prefer the one matching the .app name
    app_name = os.path.basename(app_path).replace(".app", "")
    for entry in entries:
        if entry == app_name:
            return os.path.join(macos_dir, entry)
    return os.path.join(macos_dir, entries[0])

def find_running_dev_instance(dev_roots):
    for root in dev_roots:
        electron_app = os.path.join(root, "node_modules/electron/dist/Electron.app")
        electron_bin = os.path.join(electron_app, "Contents/MacOS/Electron")
        try:
            result = subprocess.run(
                ["pgrep", "-qf", electron_bin],
                capture_output=True,
            )
            if result.returncode == 0:
                return electron_app
        except Exception:
            continue
    return None

def main():
    parser = argparse.ArgumentParser(
        description="Brett's Rad Preview Tool",
        usage="brpt [file ...] | brpt --diff <new-file> <diff-file> | brpt --diff-by-files <new-file> <old-file>",
    )

    mode = parser.add_mutually_exclusive_group()
    mode.add_argument(
        "--diff",
        nargs=2,
        metavar=("NEW_FILE", "DIFF_FILE"),
        help="Open a diff view from a file and a unified diff file",
    )
    mode.add_argument(
        "--diff-by-files",
        nargs=2,
        metavar=("NEW_FILE", "OLD_FILE"),
        help="Open a diff view computed from two files",
    )
    parser.add_argument(
        "--annotate",
        metavar="ANNOTATION_FILE",
        help="Attach an annotation JSON file to the opened tab",
    )
    parser.add_argument(
        "files",
        nargs="*",
        help="Markdown files to open",
    )

    args = parser.parse_args()

    config_path = os.environ.get("BRPT_CONFIG") or os.path.join(
        os.path.expanduser("~"), ".brpt", "brpt-config.json"
    )
    app_path = find_app_path()
    dev_roots = load_dev_roots(config_path)
    dev_app = find_running_dev_instance(dev_roots)
    target_app = dev_app or app_path

    # When invoking Electron directly (for --annotate or --diff), it needs
    # an entry point. In dev mode, pass the project root so Electron reads
    # package.json → main. For packaged apps, the entry is baked in.
    dev_entry = []
    if dev_app:
        for root in dev_roots:
            electron_app = os.path.join(root, "node_modules/electron/dist/Electron.app")
            if os.path.normpath(electron_app) == os.path.normpath(target_app):
                dev_entry = [root]
                break

    had_error = False

    if args.diff or args.diff_by_files:
        if args.diff:
            new_file, second_file = args.diff
            flag = "--diff"
        else:
            new_file, second_file = args.diff_by_files
            flag = "--diff-by-files"

        for path in [new_file, second_file]:
            if not os.path.isfile(path):
                print(f"brpt: {path}: No such file", file=sys.stderr)
                sys.exit(1)

        new_file = resolve_path(new_file)
        second_file = resolve_path(second_file)

        # Launch the binary directly so Electron's single-instance lock
        # forwards args to a running instance via the second-instance event.
        app_bin = find_app_binary(target_app)
        cmd = [app_bin] + dev_entry + [flag, new_file, second_file]
        if args.annotate:
            annotate_path = resolve_path(args.annotate)
            if not os.path.isfile(annotate_path):
                print(f"brpt: {args.annotate}: No such file", file=sys.stderr)
                sys.exit(1)
            cmd.append(f"--annotate={annotate_path}")
        subprocess.run(cmd)
        sys.exit(0)

    annotate_arg = None
    if args.annotate:
        annotate_path = resolve_path(args.annotate)
        if not os.path.isfile(annotate_path):
            print(f"brpt: {args.annotate}: No such file", file=sys.stderr)
            sys.exit(1)
        annotate_arg = f"--annotate={annotate_path}"

    resolved_files = []
    for path in args.files:
        if os.path.isfile(path):
            resolved_files.append(resolve_path(path))
        else:
            print(f"brpt: {path}: No such file", file=sys.stderr)
            had_error = True

    if args.files and not resolved_files:
        sys.exit(1)

    if annotate_arg:
        # Must use binary directly so --annotate gets forwarded through
        # Electron's single-instance lock (macOS `open` strips extra args).
        app_bin = find_app_binary(target_app)
        cmd = [app_bin] + dev_entry + resolved_files + [annotate_arg]
        subprocess.run(cmd)
    elif resolved_files:
        subprocess.run(["open", "-a", target_app] + resolved_files)
    else:
        subprocess.run(["open", "-a", target_app])

    if had_error:
        sys.exit(1)

if __name__ == "__main__":
    main()
